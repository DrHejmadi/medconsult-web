# ============================================
# MedConsult Environment Configuration
# ============================================
# Kopier denne fil til .env.local og udfyld med dine vaerdier

# Supabase — Opret projekt paa https://supabase.com
# Vaelg region: EU (Frankfurt) for GDPR compliance
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — Opret konto paa https://stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_...

# MitID — Kraever broker-aftale med Idura/Criipto eller Signaturgruppen
# Lad staa tomme indtil aftale er indgaaet
MITID_AUTHORITY=
MITID_CLIENT_ID=
MITID_CLIENT_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
